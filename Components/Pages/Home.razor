@page "/"
@implements IDisposable
@rendermode InteractiveServer

@inject ChatStateService ChatState
@inject IChatService ChatService
@inject IJSRuntime JS

@if (ChatState.IdSelectedChat == Guid.Empty)
{
    @if (Sending)
    {
        <div class="welcome-container">
            <h1>Bem-vindo(a)</h1>
            <p>O que está pensando?</p>
            <div class="message bot loading-message">
                <span class="loading-dot"></span>
                <span class="loading-dot"></span>
                <span class="loading-dot"></span>
            </div>
        </div>
    }
    else{
        <div class="welcome-container">
            <h1>Bem-vindo(a)</h1>
            <p>O que está pensando?</p>
            <div class="input-area welcome">
                <input placeholder="Digite algo para começar..." @bind="Message" @bind:event="oninput" @onkeydown="HandleInputKeyDown" />

                <button @onclick="SendMessage" disabled="@Sending">➤</button>
            </div>
        </div>
    }   
}
else
{
    <div class="chat-header">
        <div class="chat-title">@CurrentChatTitle</div>
    </div>

    <div class="messages" @ref="MessagesContainer">
        @foreach (var msg in Messages)
        {
            <div class="message-row @(msg.Role == "user" ? "user-row" : "bot-row")">
                @if (IsBotMessage(msg))
                {
                    <div class="avatar">
                        <img src="logo.png" class="img-logo" />
                    </div>
                }

                <div class="message @(msg.Role == "user" ? "user" : "bot")">
                    @msg.Content
                </div>

                @if (msg.Role == "user")
                {
                    <div class="avatar user-avatar">C</div>
                }
            </div>
        }

        @if (Sending)
        {
            <div class="message-row bot-row">
                <div class="avatar">
                    <img src="logo.png" class="img-logo" />
                </div>
                <div class="message bot loading-message">
                    <span class="loading-dot"></span>
                    <span class="loading-dot"></span>
                    <span class="loading-dot"></span>
                </div>
            </div>
        }
    </div>

    <div class="input-area">
        <input placeholder="Escreva sua mensagem aqui..." @bind="Message" @bind:event="oninput" @onkeydown="HandleInputKeyDown" />
        <button @onclick="SendMessage" disabled="@Sending">➤</button>
    </div>
}

@code {
    List<ChatMessage> Messages = new();
    string CurrentChatTitle = "Novo chat";
    string Message = string.Empty;
    bool Sending;
    bool ShouldScrollDown;
    ElementReference MessagesContainer;

    #region [LOAD]
    protected override void OnInitialized()
    {
        ChatState.OnChange += LoadChat;
    }

    async void LoadChat()
    {
        var chatId = ChatState.IdSelectedChat;

        if (chatId == Guid.Empty)
        {
            Messages.Clear();
            CurrentChatTitle = "Novo chat";
            Sending = false;
            ShouldScrollDown = false;
            await InvokeAsync(StateHasChanged);
            return;
        }

        Messages = await ChatService.GetMessagesAsync(chatId);
        var chats = await ChatService.ListChatsAsync();
        CurrentChatTitle = chats.FirstOrDefault(c => c.Id == chatId)?.Name ?? "Chat";
        ShouldScrollDown = true;

        await InvokeAsync(StateHasChanged);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (ShouldScrollDown && ChatState.IdSelectedChat != Guid.Empty)
        {
            ShouldScrollDown = false;
            await JS.InvokeVoidAsync("chatScroll.scrollToBottom", MessagesContainer);
        }
    }

    #endregion [LOAD]

    #region [SEND]
    async Task SendMessage()
    {
        if (Sending || string.IsNullOrWhiteSpace(Message))
        {
            return;
        }

        var UserMessage = Message.Trim();

        Message = string.Empty;
        Sending = true;

        Messages.Add(new ChatMessage
        {
            Role = "user",
            Content = UserMessage
        });

        ShouldScrollDown = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            if (ChatState.IdSelectedChat == Guid.Empty)
            {
                var newId = await ChatService.CreateChatAsync(UserMessage);

                ChatState.SelectChat(newId);

                Messages = await ChatService.GetMessagesAsync(newId);
                var chats = await ChatService.ListChatsAsync();
                CurrentChatTitle = chats.FirstOrDefault(c => c.Id == newId)?.Name ?? "Chat";
                ShouldScrollDown = true;
                return;
            }

            await ChatService.SendMessageAsync(ChatState.IdSelectedChat, UserMessage);
            Messages = await ChatService.GetMessagesAsync(ChatState.IdSelectedChat);
            ShouldScrollDown = true;
        }
        finally
        {
            Sending = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    #endregion [SEND]

    #region [ANIMATION]
    async Task HandleInputKeyDown(KeyboardEventArgs e)
    {   
        if (e.Key == "Enter")
        {
            await SendMessage();
        }
    }

    bool IsBotMessage(ChatMessage msg) => msg.Role is "assistant" or "bot";

    public void Dispose()
    {
        ChatState.OnChange -= LoadChat;
    }

    #endregion [ANIMATION]
}
